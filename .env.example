# ===========================================
# CẤU HÌNH MÔI TRƯỜNG - VOCAB PROJECT
# ===========================================
# ⚠️ HƯỚNG DẪN SỬ DỤNG:
# 1. Copy file này thành .env
# 2. Điền các giá trị thực của bạn
# 3. KHÔNG bao giờ commit file .env lên Git
# ===========================================

# --- DATABASE CONFIGURATION ---
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=english_learning
DB_CHARSET=utf8mb4

# --- SITE CONFIGURATION ---
SITE_NAME="VOCAB - English Learning"
SITE_URL=http://localhost/VOCAB
SITE_EMAIL=admin@vocab.com

# --- FACEBOOK OAUTH ---
# Tạo Facebook App tại: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET
FACEBOOK_REDIRECT_URI=http://localhost/VOCAB/auth/facebook-callback.php
FACEBOOK_API_VERSION=v18.0

# --- GOOGLE OAUTH ---
# Tạo Google OAuth Client tại: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost/VOCAB/auth/google-callback.php

# --- EMAIL CONFIGURATION (GMAIL SMTP) ---
# Hướng dẫn lấy App Password:
# 1. Truy cập: https://myaccount.google.com/security
# 2. Bật "Xác minh 2 bước"
# 3. Tạo "Mật khẩu ứng dụng" → Chọn Mail → Copy 16 ký tự
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_16_chars
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=VOCAB System

# --- SESSION CONFIGURATION ---
SESSION_LIFETIME=3600
SESSION_SECURE=0
# Đổi SESSION_SECURE=1 khi dùng HTTPS trong production

# --- ENVIRONMENT ---
APP_ENV=development
# Đổi thành 'production' khi deploy lên server thật
APP_DEBUG=true
# Đổi thành 'false' trong production để ẩn lỗi
